# ============================================================
# Environment Configuration — copy to .env and fill in values
# ============================================================

# Application
APP_NAME="Learning Recommendation System"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=production

# Server
HOST=0.0.0.0
PORT=8000

# Dataset
DATASET_PATH=data/courses.csv

# Groq AI  (get a free key at https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# CORS
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000,http://localhost:5500,http://127.0.0.1:5500

# Recommendation Engine
MIN_RECOMMENDATION_SCORE=0.05
MAX_RECOMMENDATIONS=20
DEFAULT_RECOMMENDATIONS=10
